    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const d = item.json || {};\n\n  const toNumber = (v) => {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : 0;\n  };\n\n  // ---------- LEADS ----------\n  let leads = 0;\n\n  if (Array.isArray(d.actions)) {\n    const leadAction = d.actions.find(a =>\n      (a.action_type || \"\").toLowerCase() === \"lead\"\n    );\n    if (leadAction) {\n      leads = toNumber(leadAction.value);\n    }\n  }\n\n  // ---------- CPL ----------\n  let cpl = 0;\n\n  if (Array.isArray(d.cost_per_action_type)) {\n    const leadCost = d.cost_per_action_type.find(a =>\n      (a.action_type || \"\").toLowerCase() === \"lead\"\n    );\n    if (leadCost) {\n      cpl = toNumber(leadCost.value);\n    }\n  }\n\n  // If CPL missing but leads exist → calculate\n  if (!cpl && leads > 0) {\n    cpl = toNumber(d.spend) / leads;\n  }\n\n  return {\n    json: {\n      date: d.date_start || \"\",\n      level: d._level || \"\",\n\n      campaign_id: d.campaign_id || \"\",\n      campaign_name: d.campaign_name || \"\",\n\n      adset_id: d.adset_id || \"\",\n      adset_name: d.adset_name || \"\",\n\n      ad_id: d.ad_id || \"\",\n      ad_name: d.ad_name || \"\",\n\n      spend: toNumber(d.spend),\n      impressions: toNumber(d.impressions),\n      cpm: toNumber(d.cpm),\n      ctr: toNumber(d.ctr),\n      cpc: toNumber(d.cpc),\n      frequency: toNumber(d.frequency),\n\n      leads,\n      cpl\n    }\n  };\n});"
      },
      "id": "8d16f423-e222-49c4-95e1-076c56a1b208",
