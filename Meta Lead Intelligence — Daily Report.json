        "jsCode": "// NODE 2 — Set Date Variables (run once)\nconst now = new Date();\nconst IST_OFFSET_MS = 5.5 * 60 * 60 * 1000;\n\nfunction toISTDate(date) {\n  const ist = new Date(date.getTime() + IST_OFFSET_MS);\n  return ist.toISOString().split(\"T\")[0];\n}\n\nconst yesterday           = toISTDate(new Date(now - 86400000));\nconst rolling_window_start = toISTDate(new Date(now - 4 * 86400000));\n\nreturn [{ json: { yesterday, rolling_window_start } }];"
      },
