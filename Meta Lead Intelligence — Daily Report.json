    {
      "parameters": {
        "jsCode": "// NODE 12 — Rolling 3-Day Avg + Inject Baseline\nconst sheetsItems  = $(\"GSheets: Read Baseline\").all();\nconst currentItems = $(\"Code: Normalize\").all();\nconst yesterday    = currentItems[0]?.json?.date || \"\";\n\nconst yDate  = new Date(yesterday);\nconst cutoff = new Date(yDate);\ncutoff.setDate(cutoff.getDate() - 3);\nconst cutoffStr = cutoff.toISOString().split(\"T\")[0];\n\nconst rollingRows = sheetsItems.filter(item => {\n  const r = item.json;\n  const d = r[\"Date\"] || r[\"date\"] || \"\";\n  const l = r[\"Level\"] || r[\"level\"] || \"\";\n  return l === \"Campaign\" && d >= cutoffStr && d < yesterday;\n});\n\nconst mean = arr => arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : 0;\nlet avg_ctr = 0, avg_cpl = 0;\n\nif (rollingRows.length > 0) {\n  avg_ctr = mean(rollingRows.map(r => parseFloat(r.json[\"CTR\"] || 0)).filter(v => v > 0));\n  avg_cpl = mean(rollingRows.map(r => parseFloat(r.json[\"CPL\"] || 0)).filter(v => v > 0));\n}\n\n// Fallback: use today's data if no sheet history exists (first run)\nif (!avg_ctr || !avg_cpl) {\n  const camps = currentItems.filter(i => i.json.level === \"Campaign\");\n  if (!avg_ctr) avg_ctr = mean(camps.map(i => i.json.ctr).filter(v => v > 0));\n  if (!avg_cpl) avg_cpl = mean(camps.map(i => i.json.cpl).filter(v => v > 0));\n}\n\nconst r2 = v => Math.round(v * 100) / 100;\nreturn currentItems.map(item => ({\n  json: { ...item.json, account_avg_ctr: r2(avg_ctr), account_avg_cpl: r2(avg_cpl) }\n}));"
      },
      "id": "c3b43cc1-2d33-4d79-9313-696fbb92e56d",
      "name": "Code: Rolling Baseline",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2608,
        912
      ]
    },
    {
      "parameters": {
        "jsCode": "// NODE 13 — Build Claude Payload\nconst items    = $input.all();\nconst campaigns = items.filter(i => i.json.level === \"Campaign\");\nconst adsets    = items.filter(i => i.json.level === \"Adset\");\nconst ads       = items.filter(i => i.json.level === \"Ad\");\n\nconst payload = {\n  date: items[0]?.json?.date || \"\",\n  account_avg_ctr: items[0]?.json?.account_avg_ctr || 0,\n  account_avg_cpl: items[0]?.json?.account_avg_cpl || 0,\n  baseline_type: \"rolling_3_day_average\",\n  campaigns: campaigns.map(c => {\n    const camp = c.json;\n    const campAdsets = adsets.filter(a => a.json.campaign_name === camp.campaign_name);\n    return {\n      campaign_name: camp.campaign_name,\n      spend: camp.spend, impressions: camp.impressions, cpm: camp.cpm,\n      ctr: camp.ctr, cpc: camp.cpc, frequency: camp.frequency,\n      leads: camp.leads, cpl: camp.cpl,\n      flag_no_leads: camp.flag_no_leads,\n      flag_high_spend_no_leads: camp.flag_high_spend_no_leads,\n      adsets: campAdsets.map(a => {\n        const as = a.json;\n        const asAds = ads.filter(ad =>\n          ad.json.adset_name === as.adset_name &&\n          ad.json.campaign_name === as.campaign_name);\n        return {\n          adset_name: as.adset_name, spend: as.spend, ctr: as.ctr,\n          cpc: as.cpc, frequency: as.frequency, leads: as.leads, cpl: as.cpl,\n          ads: asAds.map(ad => ({\n            ad_name: ad.json.ad_name, spend: ad.json.spend,\n            ctr: ad.json.ctr, cpc: ad.json.cpc, frequency: ad.json.frequency,\n            leads: ad.json.leads, cpl: ad.json.cpl\n          }))\n        };\n      })\n    };\n  })\n};\n\nreturn [{ json: { payload: JSON.stringify(payload) } }];"
      },
      "id": "6b4d794a-0a70-4e00-aafe-3aef43ced30a",
      "name": "Code: Build Claude Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2832,
        912
      ]
    },
    {
      "parameters": {
        "jsCode": "// NODE — Parse Claude AI Agent Output (LangChain Version)\n\nconst response = $input.first().json;\n\n// Claude AI Agent (LangChain) returns:\nconst raw = response?.output || \"\";\n\nif (!raw || typeof raw !== \"string\") {\n  throw new Error(\"CLAUDE_PARSE_FAIL: No output field from Claude Agent\");\n}\n\n// Try to parse as pure JSON first\ntry {\n  return [{ json: JSON.parse(raw) }];\n} catch (e) {\n  // If not pure JSON, try extracting first { ... } block\n  const firstBrace = raw.indexOf(\"{\");\n  const lastBrace = raw.lastIndexOf(\"}\");\n\n  if (firstBrace !== -1 && lastBrace !== -1) {\n    const jsonString = raw.slice(firstBrace, lastBrace + 1);\n    try {\n      return [{ json: JSON.parse(jsonString) }];\n    } catch (err) {\n      throw new Error(\n        \"CLAUDE_PARSE_FAIL: Could not parse JSON from output | Extracted: \" +\n          jsonString.slice(0, 300)\n      );\n    }\n  }\n\n  throw new Error(\n    \"CLAUDE_PARSE_FAIL: No valid JSON found | Raw: \" +\n      raw.slice(0, 300)\n  );\n}"
      },
      "id": "4539edb8-af72-44b0-a025-2cc524bca311",
      "name": "Code: Parse Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3408,
        912
      ]
    },
    {
      "parameters": {
        "jsCode": "// NODE 16 — Merge Raw Data + AI Analysis\nconst claude  = $(\"Code: Parse Claude\").first().json;\nconst dataAll = $(\"Code: Rolling Baseline\").all();\n\nconst campMap  = {};\nconst adsetMap = {};\nconst adMap    = {};\n\n(claude.campaign_analysis || []).forEach(c => { campMap[c.campaign_name] = c; });\n(claude.adset_analysis || []).forEach(a => {\n  adsetMap[a.campaign_name + \"|\" + a.adset_name] = a;\n});\n(claude.ad_analysis || []).forEach(a => {\n  adMap[a.campaign_name + \"|\" + a.adset_name + \"|\" + a.ad_name] = a;\n});\n\nreturn dataAll.map(item => {\n  const d = item.json;\n  let info = {};\n  if (d.level === \"Campaign\")\n    info = campMap[d.campaign_name] || {};\n  else if (d.level === \"Adset\")\n    info = adsetMap[d.campaign_name + \"|\" + d.adset_name] || {};\n  else if (d.level === \"Ad\")\n    info = adMap[d.campaign_name + \"|\" + d.adset_name + \"|\" + d.ad_name] || {};\n  return { json: { ...d,\n    health_score:   info.health_score || \"\",\n    risk_flags:     Array.isArray(info.risk_flags) ? info.risk_flags.join(\", \") : \"\",\n    recommendation: info.recommendation || \"\",\n    urgency:        info.urgency || \"\"\n  }};\n});"
      },
      "id": "cc213be1-d698-4752-a38a-4f7cb875bf53",
      "name": "Code: Merge Data + AI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
