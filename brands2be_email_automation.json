        "functionCode": "return items.filter(i => {\n  const email = (i.json.Email || '').toString().trim();\n  const action = (i.json.action || '').toString().trim().toLowerCase();\n  return email && action !== 'sent';\n});"
      },
      "id": "d95e3a48-cc1f-41ff-bf57-64b6bdfe74dc",
      "name": "Filter Pending",
      "type": "n8n-nodes-base.function",
