    {
      "parameters": {
        "jsCode": "// Randomize rows and limit to 300 unique emails\nconst LIMIT = 300;\nlet arr = items.map(x => ({ json: x.json }));\n\n// Shuffle\nfor (let i = arr.length - 1; i > 0; i--) {\n  const j = Math.floor(Math.random() * (i + 1));\n  [arr[i], arr[j]] = [arr[j], arr[i]];\n}\n\n// Today's date in IST (DATE ONLY, no time)\nconst todayIST = new Date().toLocaleString(\"en-CA\", {\n  timeZone: \"Asia/Kolkata\",\n  year: \"numeric\",\n  month: \"2-digit\",\n  day: \"2-digit\"\n}); \n// en-CA gives ISO YYYY-MM-DD\n\n// Unique & limit\nconst seen = new Set();\nconst out = [];\n\nfor (const it of arr) {\n  const email = (it.json.Email || '').toLowerCase().trim();\n  if (!email) continue;\n\n  if (!seen.has(email)) {\n    seen.add(email);\n\n    // Add only date (IST)\n    it.json.today_date = todayIST;\n\n    out.push(it);\n\n    if (out.length >= LIMIT) break;\n  }\n}\n\nreturn out;\n\n"
      },
